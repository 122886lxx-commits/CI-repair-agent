NODE_ENV=development
APP_URL=http://127.0.0.1:3000
AUTH_BYPASS=true
SESSION_SECRET=replace-with-a-long-random-string
ALLOWED_GITHUB_ORGS=your-org
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/ci_repair_agent
SANDBOX_IMAGE=node:22-bookworm
LIVE_SANDBOX=false
SANDBOX_NETWORK_DISABLED=true
GIT_AUTHOR_NAME=CI Repair Agent
GIT_AUTHOR_EMAIL=ci-repair-agent@example.com
